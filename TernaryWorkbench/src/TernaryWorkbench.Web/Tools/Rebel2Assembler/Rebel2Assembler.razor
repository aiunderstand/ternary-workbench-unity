@page "/rebel2-assembler"
@using TernaryWorkbench.RebelAssembler
@using TernaryWorkbench.RebelAssembler.Assembly.Models
@using System.IO
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Ternary Workbench — REBEL-2 Assembler</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">REBEL-2 Assembler / Disassembler</MudText>

<MudGrid Spacing="3">

    <!-- ISA selector -->
    <MudItem xs="12">
        <MudRadioGroup T="string" @bind-Value="_isa">
            <MudRadio T="string" Value="@Isa.Rebel2" Color="Color.Primary">REBEL-2</MudRadio>
            <MudRadio T="string" Value="@Isa.Rebel2v2" Color="Color.Primary">REBEL-2v2</MudRadio>
            <MudRadio T="string" Value="@Isa.Rebel6" Color="Color.Primary">REBEL-6</MudRadio>
        </MudRadioGroup>
    </MudItem>

    <!-- Mode selector -->
    <MudItem xs="12">
        <MudRadioGroup T="AssemblerMode" @bind-Value="_mode" @bind-Value:after="OnModeChanged">
            <MudRadio T="AssemblerMode" Value="AssemblerMode.Assemble" Color="Color.Primary">Assemble</MudRadio>
            <MudRadio T="AssemblerMode" Value="AssemblerMode.Disassemble" Color="Color.Primary">Disassemble</MudRadio>
        </MudRadioGroup>
    </MudItem>

    <!-- Input -->
    <MudItem xs="12">
        <MudTextField @bind-Value="_inputText"
                      Label="@InputLabel"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Lines="6"
                      Immediate="false"
                      Placeholder="@InputPlaceholder" />
    </MudItem>

    <!-- Action button -->
    <MudItem xs="12">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="RunAsync">
                @(_mode == AssemblerMode.Assemble ? "Assemble" : "Disassemble")
            </MudButton>
            <MudButton Variant="Variant.Text"
                       OnClick="ClearInput">
                Clear
            </MudButton>
        </MudStack>
    </MudItem>

    <!-- Error -->
    @if (_errorMessage is not null)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
                @_errorMessage
            </MudAlert>
        </MudItem>
    }

    <!-- Results table -->
    @if (_results.Count > 0)
    {
        <MudItem xs="12">
            <MudText Typo="Typo.h6" GutterBottom="true">Result</MudText>
            <MudTable Items="@_results" Dense="true" Striped="true" Bordered="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Address</MudTh>
                    @if (_mode == AssemblerMode.Assemble)
                    {
                        <MudTh>Assembly</MudTh>
                        <MudTh>Machine Code</MudTh>
                    }
                    else
                    {
                        <MudTh>Machine Code</MudTh>
                        <MudTh>Assembly</MudTh>
                    }
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-family:monospace">@context.Address</MudTd>
                    @if (_mode == AssemblerMode.Assemble)
                    {
                        <MudTd Style="font-family:monospace">@context.AssemblyText</MudTd>
                        <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                    }
                    else
                    {
                        <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                        <MudTd Style="font-family:monospace">@context.AssemblyText</MudTd>
                    }
                    <MudTd>
                        <MudTooltip Text="Copy machine code">
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           OnClick="@(() => CopyAsync(context.MachineCode))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    }

    <!-- History actions -->
    <MudItem xs="12">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(_history.Count == 0)"
                       OnClick="DownloadHistoryAsync">
                Download CSV
            </MudButton>
            <MudFileUpload T="IBrowserFile" FilesChanged="ImportCsvAsync" Accept=".txt,.csv">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@context.OpenFilePickerAsync">
                        Import CSV
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        </MudStack>
    </MudItem>

    <!-- History table -->
    <MudItem xs="12">
        <MudText Typo="Typo.h6" GutterBottom="true">Conversion History</MudText>
        @if (_history.Count == 0)
        {
            <MudText Color="Color.Secondary">No conversions yet.</MudText>
        }
        else
        {
            <MudTable Items="@_history.AsEnumerable().Reverse()" Dense="true" Striped="true" Bordered="true" Elevation="0">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Assembly</MudTh>
                    <MudTh>Machine Code</MudTh>
                    <MudTh>ISA</MudTh>
                    <MudTh>Direction</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(_history.IndexOf(context) + 1)</MudTd>
                    <MudTd Style="font-family:monospace">@context.Assembly</MudTd>
                    <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                    <MudTd>@context.Isa</MudTd>
                    <MudTd>@context.Direction.ToString().ToLowerInvariant()</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudItem>

    <!-- Import errors -->
    @if (_importErrors.Count > 0)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Warning" ShowCloseIcon="true" CloseIconClicked="() => _importErrors.Clear()">
                <MudText><b>@_importErrors.Count row(s) could not be imported:</b></MudText>
                @foreach (var err in _importErrors)
                {
                    <MudText Typo="Typo.body2">Row @err.RowNumber: @err.Message</MudText>
                }
            </MudAlert>
        </MudItem>
    }

    <!-- Instruction set reference -->
    <MudItem xs="12">
        <MudExpansionPanels>
            @if (_isa != Isa.Rebel2v2)
            {
                <MudExpansionPanel Text="REBEL-2 Instruction Set Reference" Icon="@Icons.Material.Filled.Info">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        Instructions use balanced-ternary trits: <b>+</b>, <b>0</b>, <b>-</b>.
                        Each 10-trit word is split into five 2-trit fields.
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference" Class="mb-3">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Trits [1:0]</MudTh>
                            <MudTh>Trits [3:2]</MudTh>
                            <MudTh>Trits [5:4]</MudTh>
                            <MudTh>Trits [7:6]</MudTh>
                            <MudTh>Trits [9:8]</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">op</MudTd>
                            <MudTd Style="font-family:monospace">rs1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field54</MudTd>
                            <MudTd Style="font-family:monospace">rd1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field98</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudText Typo="Typo.body2" Class="mb-2">
                        <b>Registers:</b> X-4 (--), X-3 (-0), X-2 (-+), X-1 (0-), X0 (00, hardwired zero), X1 (0+), X2 (+-), X3 (+0), X4 (++).
                        Immediates are 2-trit balanced integers in range [-4, 4].
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_instructionReference">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Func / Rd2</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd Style="font-family:monospace">@context.FuncRd2</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Comments:</b> #, ;, $, // strip to end-of-line. "quoted" strings and (parenthesised) annotations are also removed.
                        <b>Labels</b> are resolved within a page (up to 9 instructions).
                    </MudText>
                </MudExpansionPanel>
            }
            @if (_isa == Isa.Rebel6)
            {
                <MudExpansionPanel Text="REBEL-6 Instruction Set Reference" Icon="@Icons.Material.Filled.Info">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        32-trit balanced-ternary ISA with 729 registers (X-364 … X364; X0 = hardwired zero).
                        The <b>.t</b> suffix marks ternary instructions; binary (RV32I-compatible) instructions have no suffix.
                        PC increments by 1 per instruction slot.
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference6" Class="mb-3">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Trits [31:8]</MudTh>
                            <MudTh>Trits [7:4]</MudTh>
                            <MudTh>Trits [3:0]</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">@context.F318</MudTd>
                            <MudTd Style="font-family:monospace">@context.F74</MudTd>
                            <MudTd Style="font-family:monospace">@context.F30</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                        <MudText Typo="Typo.body2">Sort by:</MudText>
                        <MudSelect T="string" @bind-Value="_rebel6SortBy" Dense="true" Variant="Variant.Outlined"
                                   Style="min-width:160px" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Mnemonic")">Mnemonic</MudSelectItem>
                            <MudSelectItem Value="@("Format")">Format</MudSelectItem>
                            <MudSelectItem Value="@("Opcode")">Opcode</MudSelectItem>
                            <MudSelectItem Value="@("Func")">Func</MudSelectItem>
                            <MudSelectItem Value="@("Category")">Category</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0"
                              Items="@SortedRebel6Instructions">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Format</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Func</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd>@context.Format</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Func</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd>@context.Category</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Opcode groups:</b> <code>++xx</code> = ternary base; <code>+0xx</code> = binary base; <code>+-xx</code> = reserved extensions.
                        2-trit opcodes (MST ≠ +) = long-immediate G/Y forms.
                        <b>Comments:</b> #, ;, $, // strip to end-of-line.
                    </MudText>
                </MudExpansionPanel>
            }
            @if (_isa == Isa.Rebel2v2)
            {
                <MudExpansionPanel Text="REBEL-2v2 Instruction Set Reference (ISA v0.5)" Icon="@Icons.Material.Filled.Info">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        Instructions use balanced-ternary trits: <b>+</b>, <b>0</b>, <b>-</b>.
                        Each 10-trit word is split into five 2-trit fields.
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference2v2" Class="mb-3">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Trits [1:0]</MudTh>
                            <MudTh>Trits [3:2]</MudTh>
                            <MudTh>Trits [5:4]</MudTh>
                            <MudTh>Trits [7:6]</MudTh>
                            <MudTh>Trits [9:8]</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">op</MudTd>
                            <MudTd Style="font-family:monospace">rs1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field54</MudTd>
                            <MudTd Style="font-family:monospace">rd1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field98</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudText Typo="Typo.body2" Class="mb-2">
                        <b>Registers:</b> X-4 (--), X-3 (-0), X-2 (-+), X-1 (0-), X0 (00, hardwired zero), X1 (0+), X2 (+-), X3 (+0), X4 (++).
                        Immediates are 2-trit balanced integers in range [-4, 4].
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_instructionReference2v2">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Func / Rd2</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd Style="font-family:monospace">@context.FuncRd2</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Comments:</b> #, ;, $, // strip to end-of-line. "quoted" strings and (parenthesised) annotations are also removed.
                        <b>Labels</b> are resolved within a page (up to 9 instructions).
                    </MudText>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </MudItem>

</MudGrid>

@code {

    private enum AssemblerMode { Assemble, Disassemble }

    // ---- UI state ----
    private string _isa = Isa.Rebel2;
    private AssemblerMode _mode = AssemblerMode.Assemble;
    private string _inputText = string.Empty;
    private string? _errorMessage;

    // ---- Result rows (latest operation) ----
    private readonly List<ResultRow> _results = new();
    private record ResultRow(string Address, string AssemblyText, string MachineCode);

    // ---- History ----
    private readonly List<AssemblyRecord> _history = new();
    private readonly List<TernaryWorkbench.RebelAssembler.CsvParseError> _importErrors = new();

    // ---- REBEL-6 sort-by state ----
    private string _rebel6SortBy = "Mnemonic";

    private string InputLabel => (_isa, _mode) switch
    {
        (Isa.Rebel6, AssemblerMode.Assemble)    => "Assembly source (REBEL-6, one instruction per line)",
        (Isa.Rebel6, AssemblerMode.Disassemble) => "Machine code (one 32-trit word per line)",
        (_, AssemblerMode.Assemble)              => "Assembly source (1–9 instructions, one per line)",
        _                                        => "Machine code (one 10-trit word per line)"
    };

    private string InputPlaceholder => (_isa, _mode) switch
    {
        (Isa.Rebel6, AssemblerMode.Assemble)    => "ADD.T X1, X2, X3\nBEQ.T X1, X0, -1\nLI.T X2, 42",
        (Isa.Rebel6, AssemblerMode.Disassemble) => "0000+-0000+000000+000000000----++--\n...",
        (_, AssemblerMode.Assemble)              => "ADD.T X1, X2, X3\nNOP.T\nJAL.T X0, 0",
        _                                        => "--+-+00+00\n-000000000"
    };

    // -------------------------------------------------------------------------
    // Event handlers
    // -------------------------------------------------------------------------

    private void OnModeChanged()
    {
        _inputText = string.Empty;
        _errorMessage = null;
        _results.Clear();
    }

    private void ClearInput()
    {
        _inputText = string.Empty;
        _errorMessage = null;
        _results.Clear();
    }

    private async Task RunAsync()
    {
        _errorMessage = null;
        _results.Clear();

        if (string.IsNullOrWhiteSpace(_inputText))
            return;

        if (_mode == AssemblerMode.Assemble)
            RunAssemble();
        else
            RunDisassemble();

        await Task.CompletedTask;
    }

    private void RunAssemble()
    {
        try
        {
            var assembled = _isa switch
            {
                Isa.Rebel2v2 => Rebel2v2Assembler.AssembleInstructions(_inputText),
                Isa.Rebel6   => Rebel6Assembler.AssembleInstructions(_inputText),
                _            => TernaryWorkbench.RebelAssembler.Rebel2Assembler.AssembleInstructions(_inputText)
            };
            foreach (var inst in assembled)
            {
                _results.Add(new ResultRow(inst.Address, inst.Assembly, inst.MachineCode));
                _history.Add(new AssemblyRecord(inst.Assembly, inst.MachineCode, _isa, AssemblyDirection.Assemble));
            }
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RunDisassemble()
    {
        var lines = _inputText
            .Split(["\r\n", "\n", "\r"], StringSplitOptions.RemoveEmptyEntries)
            .Select(l => l.Trim())
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();

        if (lines.Count == 0) return;

        bool anyErrors = false;
        var addresses6 = Rebel6Assembler.AddressSpace;
        var addresses2 = new[] { "--", "-0", "-+", "0-", "00", "0+", "+-", "+0", "++" };

        for (int i = 0; i < lines.Count; i++)
        {
            var code = lines[i];
            var address = _isa == Isa.Rebel6
                ? (i < addresses6.Length ? addresses6[i] : $"[{i}]")
                : (i < addresses2.Length ? addresses2[i] : $"[{i}]");
            try
            {
                var mnemonic = _isa switch
                {
                    Isa.Rebel2v2 => Rebel2v2Assembler.Disassemble(code),
                    Isa.Rebel6   => Rebel6Assembler.Disassemble(code),
                    _            => TernaryWorkbench.RebelAssembler.Rebel2Assembler.Disassemble(code)
                };
                _results.Add(new ResultRow(address, mnemonic, code));
                _history.Add(new AssemblyRecord(mnemonic, code, _isa, AssemblyDirection.Disassemble));
            }
            catch (InvalidOperationException ex)
            {
                _errorMessage = (_errorMessage is null ? "" : _errorMessage + "\n")
                    + $"{address} ({code}): {ex.Message}";
                anyErrors = true;
            }
        }

        if (anyErrors && _results.Count == 0)
            _results.Clear(); // nothing succeeded
    }

    // -------------------------------------------------------------------------
    // Copy / Download / Import
    // -------------------------------------------------------------------------

    private async Task CopyAsync(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { }
    }

    private async Task DownloadHistoryAsync()
    {
        string csv = AssemblyCsvSerializer.Serialize(_history);
        var filename = $"rebel_assembler_{_isa.ToLowerInvariant().Replace("-", "")}_history.csv";
        await JS.InvokeVoidAsync("downloadFile", filename, csv);
    }

    private async Task ImportCsvAsync(IBrowserFile file)
    {
        _importErrors.Clear();

        const long maxSizeBytes = 1 * 1024 * 1024;
        string csv;
        try
        {
            using var stream = file.OpenReadStream(maxSizeBytes);
            using var reader = new StreamReader(stream);
            csv = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
            return;
        }

        var (validRows, errors) = AssemblyCsvSerializer.Deserialize(csv);
        _importErrors.AddRange(errors);

        int imported = 0;
        foreach (var row in validRows)
        {
            _history.Add(row);
            imported++;
        }

        int skipped = errors.Count;
        string message = skipped > 0
            ? $"{imported} row(s) imported, {skipped} skipped."
            : $"{imported} row(s) imported successfully.";
        Snackbar.Add(message, skipped > 0 ? Severity.Warning : Severity.Success);
    }

    // -------------------------------------------------------------------------
    // Instruction reference table data
    // -------------------------------------------------------------------------

    private record FormatRef(string Name, string Field54, string Field98, string Examples);
    private record InstructionRef(string Mnemonic, string Opcode, string Operands, string FuncRd2, string Description);

    // -------------------------------------------------------------------------
    // REBEL-6 reference data
    // -------------------------------------------------------------------------

    private record FormatRef6(string Name, string F318, string F74, string F30, string Examples);
    private record InstructionRef6(string Mnemonic, string Format, string Opcode, string Func, string Operands, string Category, string Description);

    private IEnumerable<InstructionRef6> SortedRebel6Instructions => _rebel6SortBy switch
    {
        "Format"   => _instructionReference6.OrderBy(r => r.Format).ThenBy(r => r.Opcode).ThenBy(r => r.Func),
        "Opcode"   => _instructionReference6.OrderBy(r => r.Opcode).ThenBy(r => r.Func),
        "Func"     => _instructionReference6.OrderBy(r => r.Func).ThenBy(r => r.Mnemonic),
        "Category" => _instructionReference6.OrderBy(r => r.Category).ThenBy(r => r.Mnemonic),
        _          => _instructionReference6.OrderBy(r => r.Mnemonic)
    };

    private static readonly List<FormatRef6> _formatReference6 =
    [
        new("R", "rs1[6] | rs2[6] | rd1[6] | —[6]",     "func[4]",  "opcode[4]", "ADD.T, SLT.T, OR.T, AND.T, ADD, SLL"),
        new("I", "rs1[6] | imm[6] | rd1[6] | —[6]",     "func[4]",  "opcode[4]", "ADDI.T, LW.T, JALR.T, ADDI, LW, LB"),
