@page "/rebel-assembler"
@using TernaryWorkbench.RebelAssembler
@using TernaryWorkbench.RebelAssembler.Assembly.Models
@using System.IO
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Ternary Workbench — REBEL Assembler</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">REBEL Assembler / Disassembler</MudText>

<MudGrid Spacing="3">

    <!-- ISA selector -->
    <MudItem xs="12">
        <MudRadioGroup T="string" @bind-Value="_isa">
            <MudRadio T="string" Value="@Isa.Rebel2" Color="Color.Primary">REBEL-2</MudRadio>
            <MudRadio T="string" Value="@Isa.Rebel2v2" Color="Color.Primary">REBEL-2v2</MudRadio>
            <MudRadio T="string" Value="@Isa.Rebel6" Color="Color.Primary">REBEL-6</MudRadio>
        </MudRadioGroup>
    </MudItem>

    <!-- Mode selector -->
    <MudItem xs="12">
        <MudRadioGroup T="AssemblerMode" @bind-Value="_mode" @bind-Value:after="OnModeChanged">
            <MudRadio T="AssemblerMode" Value="AssemblerMode.Assemble" Color="Color.Primary">Assemble</MudRadio>
            <MudRadio T="AssemblerMode" Value="AssemblerMode.Disassemble" Color="Color.Primary">Disassemble</MudRadio>
        </MudRadioGroup>
    </MudItem>

    <!-- Input -->
    <MudItem xs="12">
        <MudTextField @bind-Value="_inputText"
                      Label="@InputLabel"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Lines="6"
                      Immediate="false"
                      Placeholder="@InputPlaceholder" />
    </MudItem>

    <!-- Action button -->
    <MudItem xs="12">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="RunAsync">
                @(_mode == AssemblerMode.Assemble ? "Assemble" : "Disassemble")
            </MudButton>
            <MudButton Variant="Variant.Text"
                       OnClick="ClearInput">
                Clear
            </MudButton>
        </MudStack>
    </MudItem>

    <!-- Error -->
    @if (_errorMessage is not null)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
                @_errorMessage
            </MudAlert>
        </MudItem>
    }

    <!-- Results table -->
    @if (_results.Count > 0)
    {
        <MudItem xs="12">
            <MudText Typo="Typo.h6" GutterBottom="true">Result</MudText>
            <MudTable Items="@_results" Dense="true" Striped="true" Bordered="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Address</MudTh>
                    @if (_mode == AssemblerMode.Assemble)
                    {
                        <MudTh>Assembly</MudTh>
                        <MudTh>Machine Code</MudTh>
                    }
                    else
                    {
                        <MudTh>Machine Code</MudTh>
                        <MudTh>Assembly</MudTh>
                    }
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-family:monospace">@context.Address</MudTd>
                    @if (_mode == AssemblerMode.Assemble)
                    {
                        <MudTd Style="font-family:monospace">@context.AssemblyText</MudTd>
                        <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                    }
                    else
                    {
                        <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                        <MudTd Style="font-family:monospace">@context.AssemblyText</MudTd>
                    }
                    <MudTd>
                        <MudTooltip Text="Copy machine code">
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           OnClick="@(() => CopyAsync(context.MachineCode))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    }

    <!-- History actions -->
    <MudItem xs="12">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Download"
                       Disabled="@(_history.Count == 0)"
                       OnClick="DownloadHistoryAsync">
                Download CSV
            </MudButton>
            <MudFileUpload T="IBrowserFile" FilesChanged="ImportCsvAsync" Accept=".txt,.csv">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Upload"
                               OnClick="@context.OpenFilePickerAsync">
                        Import CSV
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        </MudStack>
    </MudItem>

    <!-- History table -->
    <MudItem xs="12">
        <MudText Typo="Typo.h6" GutterBottom="true">Conversion History</MudText>
        @if (_history.Count == 0)
        {
            <MudText Color="Color.Secondary">No conversions yet.</MudText>
        }
        else
        {
            <MudTable Items="@_history.AsEnumerable().Reverse()" Dense="true" Striped="true" Bordered="true" Elevation="0">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Assembly</MudTh>
                    <MudTh>Machine Code</MudTh>
                    <MudTh>ISA</MudTh>
                    <MudTh>Direction</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(_history.IndexOf(context) + 1)</MudTd>
                    <MudTd Style="font-family:monospace">@context.Assembly</MudTd>
                    <MudTd Style="font-family:monospace">@context.MachineCode</MudTd>
                    <MudTd>@context.Isa</MudTd>
                    <MudTd>@context.Direction.ToString().ToLowerInvariant()</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudItem>

    <!-- Import errors -->
    @if (_importErrors.Count > 0)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Warning" ShowCloseIcon="true" CloseIconClicked="() => _importErrors.Clear()">
                <MudText><b>@_importErrors.Count row(s) could not be imported:</b></MudText>
                @foreach (var err in _importErrors)
                {
                    <MudText Typo="Typo.body2">Row @err.RowNumber: @err.Message</MudText>
                }
            </MudAlert>
        </MudItem>
    }

    <!-- Instruction set reference -->
    <MudItem xs="12">
        <MudExpansionPanels>
            @if (_isa == Isa.Rebel2)
            {
                <MudExpansionPanel Text="REBEL-2 Instruction Set Reference (V2.0)" Icon="@Icons.Material.Filled.Info">

                    <MudText Typo="Typo.subtitle2" Class="mb-1">1.1 Overview</MudText>
                    <MudText Typo="Typo.body2" Class="mb-2">
                        REBEL-2 (RISC-V-like Energy efficient Balanced tErnary Logic CPU, 2-trit address postfix) is a novel balanced ternary (radix-3)
                        CPU implemented in MRCS (logic gates synthesis, transistor level simulation), SONIC (gate level simulation, ternary HDL export for
                        FPGA/ASIC) and R2R (assembly level simulation, C to REBEL compiler toolchain). It follows Brousentsov's ternary principles:
                        ternary logic, ternary memory, and balanced ternary encoding. REBEL-2 is a modern, compact, Harvard-style ternary processor
                        optimized for simplicity and educational use rather than high-throughput, compact area commercial deployment.
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-1"><b>Key design points:</b></MudText>
                    <ul style="margin:0 0 8px 20px; font-size:0.875rem">
                        <li>Balanced ternary (+, 0, −) native implementation using MRCS standard cell library.</li>
                        <li>Harvard architecture: instructions in ROM, data in RAM; instruction and data accesses can occur in the same cycle.</li>
                        <li>Register-oriented processing (not load/store); no external memory required for processing.</li>
                        <li>Single-cycle instruction execution (instruction-read at rising edge, write at falling edge).</li>
                        <li>Multi-page programs: each page holds up to 9 instructions; labels are resolved within a page.</li>
                    </ul>

                    <MudText Typo="Typo.subtitle2" Class="mb-1">1.2 Intended Use &amp; Strengths</MudText>
                    <ul style="margin:0 0 8px 20px; font-size:0.875rem">
                        <li>Educational platform for embedded ternary computing concepts and teaching.</li>
                        <li>Low-power, simplicity-focused designs and prototyping.</li>
                        <li>Demonstrator of balanced ternary technology stack.</li>
                        <li>Easily scalable to wider address widths (e.g., tryte width) and to REBEL-6, a binary-compatible 32-trit architecture for practical applications.</li>
                    </ul>

                    <MudText Typo="Typo.subtitle2" Class="mb-1">1.3 Architecture Summary</MudText>
                    <ul style="margin:0 0 12px 20px; font-size:0.875rem">
                        <li><b>Radix:</b> Balanced ternary (trits: +, 0, −).</li>
                        <li><b>Data path width:</b> 2-trit memory address bus (postfix "−2"); 9 registers (X−4 … X4).</li>
                        <li><b>Architecture style:</b> Harvard (split instruction/data memories).</li>
                        <li><b>Model:</b> Register-processing (instructions operate on registers directly, low data movement).</li>
                        <li><b>Instruction timing:</b> Single-cycle; read at rising edge, write at falling edge.</li>
                        <li><b>ISA inspiration:</b> RISC-V principles (simplicity, shift complexity to software).</li>
                    </ul>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference" Class="mb-1">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Trits [9:8]</MudTh>
                            <MudTh>Trits [7:6]</MudTh>
                            <MudTh>Trits [5:4]</MudTh>
                            <MudTh>Trits [3:2]</MudTh>
                            <MudTh>Trits [1:0]</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">@context.Field98</MudTd>
                            <MudTd Style="font-family:monospace">rd1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field54</MudTd>
                            <MudTd Style="font-family:monospace">rs1</MudTd>
                            <MudTd Style="font-family:monospace">op</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.caption" Class="mb-3">Fields are shown MST-first (most significant trit at left).</MudText>

                    <MudText Typo="Typo.body2" Class="mb-2">
                        <b>Registers:</b> X-4 (--), X-3 (-0), X-2 (-+), X-1 (0-), X0 (00, hardwired zero), X1 (0+), X2 (+-), X3 (+0), X4 (++).
                        Immediates (imm2) are 2-trit balanced integers in range [−4, 4].
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                        <MudText Typo="Typo.body2">Sort by:</MudText>
                        <MudSelect T="string" @bind-Value="_rebel2SortBy" Dense="true" Variant="Variant.Outlined"
                                   Style="min-width:160px" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Mnemonic")">Mnemonic</MudSelectItem>
                            <MudSelectItem Value="@("Format")">Format</MudSelectItem>
                            <MudSelectItem Value="@("Opcode")">Opcode</MudSelectItem>
                            <MudSelectItem Value="@("Func")">Func</MudSelectItem>
                            <MudSelectItem Value="@("Category")">Category</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@SortedRebel2Instructions">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Format</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Func / Rd2</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd>@context.Format</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd Style="font-family:monospace">@context.FuncRd2</MudTd>
                            <MudTd>@context.Category</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Comments:</b> #, ;, $, // strip to end-of-line. "quoted" strings and (parenthesised) annotations are also removed.
                        <b>Labels</b> are resolved within a page (up to 9 instructions).
                    </MudText>
                </MudExpansionPanel>
            }
            @if (_isa == Isa.Rebel6)
            {
                <MudExpansionPanel Text="REBEL-6 Instruction Set Reference" Icon="@Icons.Material.Filled.Info">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Overview &amp; Comparison with REBEL-2</MudText>
                    <MudText Typo="Typo.body2" Class="mb-2">
                        REBEL-6 is the successor to REBEL-2, designed for real-world applications rather than education.
                        It extends REBEL-2 from a minimal 10-trit, 9-register ISA to a full 32-trit, 729-register architecture
                        with direct RV32I binary compatibility. The <b>.t</b> suffix marks ternary instructions;
                        binary (RV32I-compatible) instructions have no suffix. PC increments by 1 per instruction slot.
                    </MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Class="mb-3"
                              Items="@_rebel6Comparison">
                        <HeaderContent>
                            <MudTh>Property</MudTh>
                            <MudTh>REBEL-2</MudTh>
                            <MudTh>REBEL-6</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Property</MudTd>
                            <MudTd>@context.Rebel2</MudTd>
                            <MudTd><b>@context.Rebel6</b></MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudText Typo="Typo.subtitle2" Class="mb-1">RV32I Binary Compatibility (L-type)</MudText>
                    <MudText Typo="Typo.body2" Class="mb-3">
                        A hardware flag enables direct execution of existing RV32I 32-bit binaries — no recompilation needed.
                        Binary is a strict subset of ternary: each 32-bit RV32I instruction fits exactly in 32 trits by
                        mapping binary 0 → trit <b>−</b> and binary 1 → trit <b>+</b>. A hardware binary-ternary ALU
                        and instruction translator handle the conversion transparently. The <code>xx-0</code> opcode group
                        provides a software-accessible RV32I instruction space for explicit binary-mode code.
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference6" Class="mb-1">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Layout (MST → LST)</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">@context.Layout</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.caption" Class="mb-3">Fields shown MST-first. 4-trit opcodes: last trit = 0. 2-trit opcodes (G/Y): last trit ≠ 0.</MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                        <MudText Typo="Typo.body2">Sort by:</MudText>
                        <MudSelect T="string" @bind-Value="_rebel6SortBy" Dense="true" Variant="Variant.Outlined"
                                   Style="min-width:160px" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Mnemonic")">Mnemonic</MudSelectItem>
                            <MudSelectItem Value="@("Format")">Format</MudSelectItem>
                            <MudSelectItem Value="@("Opcode")">Opcode</MudSelectItem>
                            <MudSelectItem Value="@("Func")">Func</MudSelectItem>
                            <MudSelectItem Value="@("Category")">Category</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0"
                              Items="@SortedRebel6Instructions">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Format</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Func</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd>@context.Format</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Func</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd>@context.Category</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Opcode groups (by last 2 trits):</b> <code>xx00</code> = Base Ternary (729 slots);
                        <code>xx-0</code> = Base Binary / RV32I (729 slots); <code>xx+0</code> = Extensions (729 slots, reserved).
                        The upper 2 trits encode the instruction category — same in both ternary and binary:
                        <code>00</code>=I-type ALU, <code>0-</code>=Branch, <code>0+</code>=Store,
                        <code>--</code>=R-type ALU, <code>-+</code>=I-type Load, <code>+-</code>=D/Control, <code>+0</code>=X/Imm, <code>++</code>=System.
                        <b>Func:</b> upper 2 trits always <code>00</code>; lower 2 trits (LST) shown in table discriminate the instruction.
                        <b>2-trit long-immediate (last trit ≠ 0):</b>
                        <code>++</code> LWA.T, <code>0+</code> LI.T, <code>-+</code> SWA.T,
                        <code>+-</code> JAL.T, <code>0-</code> AIPC.T; <code>--</code> <i>reserved</i>.
                        <b>Comments:</b> #, ;, $, // strip to end-of-line.
                    </MudText>
                </MudExpansionPanel>
            }
            @if (_isa == Isa.Rebel2v2)
            {
                <MudExpansionPanel Text="REBEL-2v2 Instruction Set Reference (V2.2)" Icon="@Icons.Material.Filled.Info">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        Instructions use balanced-ternary trits: <b>+</b>, <b>0</b>, <b>-</b>.
                        Each 10-trit word is split into five 2-trit fields. Same register file and Harvard architecture as V2.0.
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Class="mb-1">Changes from V2.0 → V2.2</MudText>
                    <ul style="margin:0 0 12px 20px; font-size:0.875rem">
                        <li><b>NOP.T</b> encoding changed to <code>0000000000</code> (opcode <code>00</code>).</li>
                        <li><b>MUL.T</b> moved to opcode <code>--</code> (func <code>-0</code>); opcode <code>0-</code> now hosts MAJV.T.</li>
                        <li><b>ADDI.T, LI.T, MV.T, STI.T</b> and the Min/Max family have new opcodes.</li>
                        <li><b>New instructions:</b> MULH.T, DIV.T, REM.T, MOD.T, LD2.T, ST2.T, NTI.T, PTI.T, MTI.T, CYCLEUP.T, SWAP.T, MAJV.T, MINI.T, MAXI.T, CMPWI.T, CMPTI.T, BNE.T, KIMP.T, FENCE.T, WFI.T, IRET.T, EBREAK.T, ECALL.T.</li>
                        <li><b>Memory access:</b> LD2.T and ST2.T add optional memory load/store (V2.2 extension; base REBEL-2 is register-oriented).</li>
                        <li><b>Expanded format set:</b> R, I, D, E (MAJV 3-source), U (unary, rs2 fixed to 00).</li>
                    </ul>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Instruction Formats</b></MudText>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@_formatReference2v2" Class="mb-1">
                        <HeaderContent>
                            <MudTh>Format</MudTh>
                            <MudTh>Trits [9:8]</MudTh>
                            <MudTh>Trits [7:6]</MudTh>
                            <MudTh>Trits [5:4]</MudTh>
                            <MudTh>Trits [3:2]</MudTh>
                            <MudTh>Trits [1:0]</MudTh>
                            <MudTh>Examples</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.Name</b></MudTd>
                            <MudTd Style="font-family:monospace">@context.Field98</MudTd>
                            <MudTd Style="font-family:monospace">rd1</MudTd>
                            <MudTd Style="font-family:monospace">@context.Field54</MudTd>
                            <MudTd Style="font-family:monospace">rs1</MudTd>
                            <MudTd Style="font-family:monospace">op</MudTd>
                            <MudTd>@context.Examples</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.caption" Class="mb-3">Fields are shown MST-first (most significant trit at left).</MudText>

                    <MudText Typo="Typo.body2" Class="mb-2">
                        <b>Registers:</b> X-4 (--), X-3 (-0), X-2 (-+), X-1 (0-), X0 (00, hardwired zero), X1 (0+), X2 (+-), X3 (+0), X4 (++).
                        Immediates (imm2) are 2-trit balanced integers in range [−4, 4].
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mb-1"><b>Mnemonics</b></MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                        <MudText Typo="Typo.body2">Sort by:</MudText>
                        <MudSelect T="string" @bind-Value="_rebel2v2SortBy" Dense="true" Variant="Variant.Outlined"
                                   Style="min-width:160px" Margin="Margin.Dense">
                            <MudSelectItem Value="@("Mnemonic")">Mnemonic</MudSelectItem>
                            <MudSelectItem Value="@("Format")">Format</MudSelectItem>
                            <MudSelectItem Value="@("Opcode")">Opcode</MudSelectItem>
                            <MudSelectItem Value="@("Func")">Func</MudSelectItem>
                            <MudSelectItem Value="@("Category")">Category</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                    <MudTable Dense="true" Striped="true" Bordered="true" Elevation="0" Items="@SortedRebel2v2Instructions">
                        <HeaderContent>
                            <MudTh>Mnemonic</MudTh>
                            <MudTh>Format</MudTh>
                            <MudTh>Opcode</MudTh>
                            <MudTh>Operands</MudTh>
                            <MudTh>Func / Rd2</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family:monospace">@context.Mnemonic</MudTd>
                            <MudTd>@context.Format</MudTd>
                            <MudTd Style="font-family:monospace">@context.Opcode</MudTd>
                            <MudTd Style="font-family:monospace">@context.Operands</MudTd>
                            <MudTd Style="font-family:monospace">@context.FuncRd2</MudTd>
                            <MudTd>@context.Category</MudTd>
                            <MudTd>@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.body2" Class="mt-2">
                        <b>Comments:</b> #, ;, $, // strip to end-of-line. "quoted" strings and (parenthesised) annotations are also removed.
                        <b>Labels</b> are resolved within a page (up to 9 instructions).
                    </MudText>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </MudItem>

</MudGrid>

@code {

    private enum AssemblerMode { Assemble, Disassemble }

    // ---- UI state ----
    private string _isa = Isa.Rebel2;
    private AssemblerMode _mode = AssemblerMode.Assemble;
    private string _inputText = string.Empty;
    private string? _errorMessage;

    // ---- Result rows (latest operation) ----
    private readonly List<ResultRow> _results = new();
    private record ResultRow(string Address, string AssemblyText, string MachineCode);

    // ---- History ----
    private readonly List<AssemblyRecord> _history = new();
    private readonly List<TernaryWorkbench.RebelAssembler.CsvParseError> _importErrors = new();

    // ---- Sort-by state ----
    private string _rebel2SortBy   = "Mnemonic";
    private string _rebel2v2SortBy = "Mnemonic";
    private string _rebel6SortBy   = "Mnemonic";

    private string InputLabel => (_isa, _mode) switch
    {
        (Isa.Rebel6, AssemblerMode.Assemble)    => "Assembly source (REBEL-6, one instruction per line)",
        (Isa.Rebel6, AssemblerMode.Disassemble) => "Machine code (one 32-trit word per line)",
        (_, AssemblerMode.Assemble)              => "Assembly source (1–9 instructions, one per line)",
        _                                        => "Machine code (one 10-trit word per line)"
    };

    private string InputPlaceholder => (_isa, _mode) switch
    {
        (Isa.Rebel6, AssemblerMode.Assemble)    => "ADD.T X1, X2, X3\nBEQ.T X1, X0, -1\nLI.T X2, 42",
        (Isa.Rebel6, AssemblerMode.Disassemble) => "0000+-0000+000000+000000000----++--\n...",
        (_, AssemblerMode.Assemble)              => "ADD.T X1, X2, X3\nNOP.T\nJAL.T X0, 0",
        _                                        => "--+-+00+00\n-000000000"
    };

    // -------------------------------------------------------------------------
    // Event handlers
    // -------------------------------------------------------------------------

    private void OnModeChanged()
    {
        _inputText = string.Empty;
        _errorMessage = null;
        _results.Clear();
    }

    private void ClearInput()
    {
        _inputText = string.Empty;
        _errorMessage = null;
        _results.Clear();
    }

    private async Task RunAsync()
    {
        _errorMessage = null;
        _results.Clear();

        if (string.IsNullOrWhiteSpace(_inputText))
            return;

        if (_mode == AssemblerMode.Assemble)
            RunAssemble();
        else
            RunDisassemble();

        await Task.CompletedTask;
    }

    private void RunAssemble()
    {
        try
        {
            var assembled = _isa switch
            {
                Isa.Rebel2v2 => Rebel2v2Assembler.AssembleInstructions(_inputText),
                Isa.Rebel6   => Rebel6Assembler.AssembleInstructions(_inputText),
                _            => TernaryWorkbench.RebelAssembler.Rebel2Assembler.AssembleInstructions(_inputText)
            };
            foreach (var inst in assembled)
            {
                _results.Add(new ResultRow(inst.Address, inst.Assembly, inst.MachineCode));
                _history.Add(new AssemblyRecord(inst.Assembly, inst.MachineCode, _isa, AssemblyDirection.Assemble));
            }
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RunDisassemble()
    {
        var lines = _inputText
            .Split(["\r\n", "\n", "\r"], StringSplitOptions.RemoveEmptyEntries)
            .Select(l => l.Trim())
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();

        if (lines.Count == 0) return;

        bool anyErrors = false;
        var addresses6 = Rebel6Assembler.AddressSpace;
        var addresses2 = new[] { "--", "-0", "-+", "0-", "00", "0+", "+-", "+0", "++" };

        for (int i = 0; i < lines.Count; i++)
        {
            var code = lines[i];
            var address = _isa == Isa.Rebel6
                ? (i < addresses6.Length ? addresses6[i] : $"[{i}]")
                : (i < addresses2.Length ? addresses2[i] : $"[{i}]");
            try
            {
                var mnemonic = _isa switch
                {
                    Isa.Rebel2v2 => Rebel2v2Assembler.Disassemble(code),
                    Isa.Rebel6   => Rebel6Assembler.Disassemble(code),
                    _            => TernaryWorkbench.RebelAssembler.Rebel2Assembler.Disassemble(code)
                };
                _results.Add(new ResultRow(address, mnemonic, code));
                _history.Add(new AssemblyRecord(mnemonic, code, _isa, AssemblyDirection.Disassemble));
            }
            catch (InvalidOperationException ex)
            {
                _errorMessage = (_errorMessage is null ? "" : _errorMessage + "\n")
                    + $"{address} ({code}): {ex.Message}";
                anyErrors = true;
            }
        }

        if (anyErrors && _results.Count == 0)
            _results.Clear(); // nothing succeeded
    }

    // -------------------------------------------------------------------------
    // Copy / Download / Import
    // -------------------------------------------------------------------------

    private async Task CopyAsync(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { }
    }

    private async Task DownloadHistoryAsync()
    {
        string csv = AssemblyCsvSerializer.Serialize(_history);
        var filename = $"rebel_assembler_{_isa.ToLowerInvariant().Replace("-", "")}_history.csv";
        await JS.InvokeVoidAsync("downloadFile", filename, csv);
    }

    private async Task ImportCsvAsync(IBrowserFile file)
    {
        _importErrors.Clear();

        const long maxSizeBytes = 1 * 1024 * 1024;
        string csv;
        try
        {
            using var stream = file.OpenReadStream(maxSizeBytes);
            using var reader = new StreamReader(stream);
            csv = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
            return;
        }

        var (validRows, errors) = AssemblyCsvSerializer.Deserialize(csv);
        _importErrors.AddRange(errors);

        int imported = 0;
        foreach (var row in validRows)
        {
            _history.Add(row);
            imported++;
        }

        int skipped = errors.Count;
        string message = skipped > 0
            ? $"{imported} row(s) imported, {skipped} skipped."
            : $"{imported} row(s) imported successfully.";
        Snackbar.Add(message, skipped > 0 ? Severity.Warning : Severity.Success);
    }

    // -------------------------------------------------------------------------
    // Instruction reference table data
    // -------------------------------------------------------------------------

    private record FormatRef(string Name, string Field54, string Field98, string Examples);
    private record InstructionRef(string Mnemonic, string Format, string Opcode, string Operands, string FuncRd2, string Category, string Description);

    // -------------------------------------------------------------------------
