@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Ternary Workbench</MudText>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SwapHoriz">Radix Converter</MudNavLink>
            <MudNavLink Href="chart-string-converter" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Abc">charT-String Converter</MudNavLink>
            <MudNavLink Href="rebel2-assembler" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Memory">REBEL Assembler</MudNavLink>
            <MudNavLink Href="mrcs-studio" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schema">MRCS Studio</MudNavLink>
            <MudNavLink Disabled="true" Icon="@Icons.Material.Filled.Code">C to REBEL Compiler (soon)</MudNavLink>
            <MudNavLink Disabled="true" Icon="@Icons.Material.Filled.Timeline">Surfer Ternary Waveviewer (soon)</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6" Style="padding-bottom: 48px;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
<Footer />

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
