@page "/"

<PageTitle>Ternary Workbench — Radix Converter</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Radix Converter</MudText>

<MudGrid Spacing="3">
    <!-- Input -->
    <MudItem xs="12">
        <MudTextField @bind-Value="_inputValue"
                      Label="Input value"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentPaste"
                      OnAdornmentClick="PasteAsync"
                      Immediate="true"
                      @bind-Value:after="Recalculate" />
    </MudItem>

    <!-- From / To radix selectors -->
    <MudItem xs="12" sm="6">
        <MudSelect T="Radix" Label="From radix" @bind-Value="_fromRadix"
                   Variant="Variant.Outlined" FullWidth="true"
                   @bind-Value:after="OnSettingChanged">
            <MudSelectItem Value="@Radix.Base2Unsigned">@Radix.Base2Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base2Signed1C">@Radix.Base2Signed1C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base2Signed2C">@Radix.Base2Signed2C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base8Unsigned">@Radix.Base8Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base16Unsigned">@Radix.Base16Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base64Rfc4648">@Radix.Base64Rfc4648.DisplayName()</MudSelectItem>
            <MudDivider />
            <MudSelectItem Value="@Radix.Base3Unbalanced">@Radix.Base3Unbalanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Signed2C">@Radix.Base3Signed2C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Signed3C">@Radix.Base3Signed3C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Balanced">@Radix.Base3Balanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base9Unbalanced">@Radix.Base9Unbalanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base27Unbalanced">@Radix.Base27Unbalanced.DisplayName()</MudSelectItem>
            <MudDivider />
            <MudSelectItem Value="@Radix.Base10">@Radix.Base10.DisplayName()</MudSelectItem>
        </MudSelect>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudSelect T="Radix" Label="To radix" @bind-Value="_toRadix"
                   Variant="Variant.Outlined" FullWidth="true"
                   @bind-Value:after="OnSettingChanged">
            <MudSelectItem Value="@Radix.Base2Unsigned">@Radix.Base2Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base2Signed1C">@Radix.Base2Signed1C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base2Signed2C">@Radix.Base2Signed2C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base8Unsigned">@Radix.Base8Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base16Unsigned">@Radix.Base16Unsigned.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base64Rfc4648">@Radix.Base64Rfc4648.DisplayName()</MudSelectItem>
            <MudDivider />
            <MudSelectItem Value="@Radix.Base3Unbalanced">@Radix.Base3Unbalanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Signed2C">@Radix.Base3Signed2C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Signed3C">@Radix.Base3Signed3C.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base3Balanced">@Radix.Base3Balanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base9Unbalanced">@Radix.Base9Unbalanced.DisplayName()</MudSelectItem>
            <MudSelectItem Value="@Radix.Base27Unbalanced">@Radix.Base27Unbalanced.DisplayName()</MudSelectItem>
            <MudDivider />
            <MudSelectItem Value="@Radix.Base10">@Radix.Base10.DisplayName()</MudSelectItem>
        </MudSelect>
    </MudItem>

    <!-- Output options -->
    <MudItem xs="12" sm="6">
        <MudCheckBox @bind-Value="_lsdFirst"
                     Label="LSD first (least significant digit first)"
                     Color="Color.Primary"
                     @bind-Value:after="Recalculate" />
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudTooltip Text="@(_bctEnabled ? string.Empty : "BCT only available when output is Ternary (balanced)")">
            <MudCheckBox @bind-Value="_bctEncoding"
                         Label="BCT encoding (BSD-PNX: 10=+, 01=\u2212, 11=0)"
                         Color="Color.Primary"
                         Disabled="@(!_bctEnabled)"
                         @bind-Value:after="Recalculate" />
        </MudTooltip>
    </MudItem>

    <!-- Output -->
    <MudItem xs="12">
        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else
        {
            <MudTextField Value="@_outputValue"
                          Label="Output"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          ReadOnly="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="CopyOutputAsync" />
        }
    </MudItem>
</MudGrid>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string _inputValue = string.Empty;
    private Radix _fromRadix = Radix.Base10;
    private Radix _toRadix = Radix.Base3Balanced;
    private bool _lsdFirst;
    private bool _bctEncoding;
    private string _outputValue = string.Empty;
    private string? _errorMessage;

    private bool _bctEnabled => _toRadix.SupportsBct();

    private void OnSettingChanged()
    {
        if (!_bctEnabled) _bctEncoding = false;
        Recalculate();
    }

    private void Recalculate()
    {
        if (string.IsNullOrWhiteSpace(_inputValue))
        {
            _outputValue = string.Empty;
            _errorMessage = null;
            return;
        }
        try
        {
            var opts = new OutputOptions(LsdFirst: _lsdFirst, BctEncoding: _bctEncoding && _bctEnabled);
            _outputValue = RadixConverter.Convert(_inputValue, _fromRadix, _toRadix, opts);
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _outputValue = string.Empty;
            _errorMessage = ex.Message;
        }
    }

    private async Task PasteAsync()
    {
        try
        {
            _inputValue = await JS.InvokeAsync<string>("navigator.clipboard.readText");
            Recalculate();
        }
        catch { /* clipboard permission denied */ }
    }

    private async Task CopyOutputAsync()
    {
        if (!string.IsNullOrEmpty(_outputValue))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _outputValue);
    }
}
